{
  "name": "@lucinate-ai/concord",
  "version": "1.0.0",
  "description": "Concurrent OpenSpec for teams — drift and overlap detection for spec-driven development",
  "keywords": [
    "openspec",
    "specs",
    "spec-driven",
    "sdd",
    "drift",
    "merge",
    "concurrency",
    "cli"
  ],
  "homepage": "https://github.com/lucinate-ai/concord",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucinate-ai/concord"
  },
  "bugs": "https://github.com/lucinate-ai/concord/issues",
  "license": "Apache-2.0",
  "author": "Concord Contributors",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "concord": "./bin/concord.js"
  },
  "files": [
    "dist",
    "bin",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "concord": "pnpm build && node bin/concord.js",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "chalk": "^5.5.0",
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.2.0",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.6"
  }
}
